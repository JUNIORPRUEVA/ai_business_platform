{
  "name": "fullpos-enterprise-bot-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Runnable NestJS backend foundation for FULLPOS enterprise bot orchestration.",
  "scripts": {
    "build": "nest build",
    "test:memory": "npm run build && node --test dist/memory-architecture.test.js",
    "typeorm": "ts-node ./node_modules/typeorm/cli.js -d src/common/database/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.879.0",
    "@aws-sdk/s3-request-presigner": "^3.879.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/bullmq": "^10.1.1",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "bullmq": "^5.58.3",
    "dotenv": "^16.6.1",
    "ffmpeg-static": "^5.2.0",
    "ioredis": "^5.7.0",
    "pg": "^8.13.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.26"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/node": "^22.13.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/passport-jwt": "^4.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}